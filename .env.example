# =============================================================================
# Nimbus Web — Environment Variables
# Copy to .env.local and fill in values
# =============================================================================

# Neon Postgres (Vercel Integration — auto-populated when you add Neon)
DATABASE_URL=YOUR_NEON_POSTGRES_URL

# Upstash Redis (Vercel Integration — auto-populated when you add Upstash)
KV_REST_API_URL=YOUR_UPSTASH_REDIS_URL
KV_REST_API_TOKEN=YOUR_UPSTASH_REDIS_TOKEN

# Vercel Blob (for screenshot storage)
BLOB_READ_WRITE_TOKEN=YOUR_VERCEL_BLOB_TOKEN

# Claude API (for nightly AI audit analysis)
CLAUDE_API_KEY=YOUR_ANTHROPIC_API_KEY

# Resend (for nightly email reports)
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Your email address (where nightly reports are sent)
REPORT_EMAIL=YOUR_EMAIL_ADDRESS
